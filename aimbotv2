-- ================== FIXED AIMBOT (FOV + Camera Stick) ==================
local function startAimbot()
    RunService:UnbindFromRenderStep(AIMBOT_RENDER_NAME)
    
    RunService:BindToRenderStep(AIMBOT_RENDER_NAME, Enum.RenderPriority.Camera.Value + 200, function()
        if not on then return end
        local target = getBestTargetInFOV()
        if not target then return end

        local hrp = getHRP()
        if hrp then
            local currentCamPos = cam.CFrame.Position
            local relativeOffset = currentCamPos - hrp.Position
            cam.CFrame = CFrame.new(hrp.Position + relativeOffset, target.Position)
        end
    end)
end

local function stopAimbot()
    RunService:UnbindFromRenderStep(AIMBOT_RENDER_NAME)
end
