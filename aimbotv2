local playerRows = {}

local function buildPlayerList()
    for _, r in ipairs(playerRows) do pcall(function() r:Destroy() end) end
    playerRows = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end

        local isListed = isBlacklisted(p)
        local row = Instance.new("TextButton")
        row.Size = UDim2.new(1,0,0,28)
        row.BackgroundColor3 = isListed and Color3.fromRGB(50,20,20) or T.Card2
        row.Text = ""; row.AutoButtonColor = false; row.BorderSizePixel = 0
        row.ZIndex = 3; row.Parent = scroll
        Corner(row, 6)
        if isListed then Stroke(row, T.Red, 1) else Stroke(row, T.Border, 1) end

        local nameLbl = Lbl({Size = UDim2.new(1,-36,1,0), Position = UDim2.new(0,8,0,0),
            Text = p.Name, TextColor3 = isListed and T.Red or T.Text,
            Font = Enum.Font.Gotham, TextSize = 11,
            TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4}, row)

        local badge = Lbl({Size = UDim2.new(0,28,0,18), Position = UDim2.new(1,-32,0.5,-9),
            Text = isListed and "BL" or "OK",
            TextColor3 = isListed and T.Red or T.Green,
            Font = Enum.Font.GothamBold, TextSize = 9, ZIndex = 4}, row)

        row.MouseButton1Click:Connect(function()
            local added = toggleBlacklist(p.Name)
            row.BackgroundColor3 = added and Color3.fromRGB(50,20,20) or T.Card2
            nameLbl.TextColor3   = added and T.Red or T.Text
            badge.Text           = added and "BL" or "OK"
            badge.TextColor3     = added and T.Red or T.Green
        end)

        table.insert(playerRows, row)
    end
end

