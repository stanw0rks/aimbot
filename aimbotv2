-- ================== FOV SETTINGS ==================
local FOV_RADIUS = 150                    -- laki ng bilog (pwede mo baguhin)
local AIMBOT_RENDER_NAME = "MobileFOVAimbot"
-- =================================================

local function getHRP()
    local c = lp.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function isBlacklisted(player)
    for _, name in ipairs(blacklist) do
        if name == player.Name then return true end
    end
    return false
end

local function toggleBlacklist(name)
    for i, v in ipairs(blacklist) do
        if v == name then
            table.remove(blacklist, i)
            return false
        end
    end
    table.insert(blacklist, name)
    return true
end

-- ================== NEW: GET TARGET INSIDE CIRCLE ==================
local function getBestTargetInFOV()
    local hrp = getHRP()
    if not hrp then return nil end

    local bestDist = math.huge
    local bestHead = nil

    local circleCenter = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if isBlacklisted(p) then continue end

        local char = p.Character
        if not char then continue end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local head = char:FindFirstChild("Head")
        if not head then continue end

        local screenPos, onScreen = cam:WorldToViewportPoint(head.Position)
        if not onScreen or screenPos.Z < 0 then continue end

        local distToCenter = (Vector2.new(screenPos.X, screenPos.Y) - circleCenter).Magnitude
        if distToCenter > FOV_RADIUS then continue end

        -- closest sa loob ng circle
        local dist = (hrp.Position - head.Position).Magnitude
        if dist < bestDist then
            bestDist = dist
            bestHead = head
        end
    end
    return bestHead
end
