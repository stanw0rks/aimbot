local PAD = 14
local curY = 62

local function makeSectionLabel(label)
    Lbl({
        Size = UDim2.new(1,-PAD*2,0,14), Position = UDim2.new(0,PAD,0,curY),
        Text = label:upper(), TextColor3 = T.Muted,
        Font = Enum.Font.GothamBold, TextSize = 9,
        TextXAlignment = Enum.TextXAlignment.Left,
        LetterSpacing = 2, ZIndex = 2,
    }, win)
    -- divider
    local div = Instance.new("Frame")
    div.Size = UDim2.new(1,-PAD*2,0,1); div.Position = UDim2.new(0,PAD,0,curY+14)
    div.BackgroundColor3 = T.Border; div.BorderSizePixel = 0; div.ZIndex = 2; div.Parent = win
    curY = curY + 20
end

local function makeToggleRow(label, desc, defaultVal, onToggle)
    local ROW_H = 44

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-PAD*2,0,ROW_H); row.Position = UDim2.new(0,PAD,0,curY)
    row.BackgroundColor3 = T.Card; row.BorderSizePixel = 0; row.ZIndex = 2; row.Parent = win
    Corner(row, 8); Stroke(row, T.Border)

    Lbl({ Size=UDim2.new(1,-70,0,20), Position=UDim2.new(0,12,0,6),
        Text=label, TextColor3=T.Text, Font=Enum.Font.GothamSemibold, TextSize=13,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3 }, row)

    if desc and desc ~= "" then
        Lbl({ Size=UDim2.new(1,-70,0,14), Position=UDim2.new(0,12,0,26),
            Text=desc, TextColor3=T.Dim, Font=Enum.Font.Gotham, TextSize=10,
            TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3 }, row)
    end

    -- Track
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0,42,0,22); track.Position = UDim2.new(1,-54,0.5,-11)
    track.BackgroundColor3 = defaultVal and T.Accent or T.Muted
    track.BorderSizePixel = 0; track.ZIndex = 3; track.Parent = row; Corner(track, 11)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,16,0,16); thumb.Position = UDim2.new(0,defaultVal and 23 or 3,0.5,-8)
    thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    thumb.BorderSizePixel = 0; thumb.ZIndex = 4; thumb.Parent = track; Corner(thumb, 8)

    local val = defaultVal
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1,0,1,0); btn.BackgroundTransparency = 1
    btn.Text = ""; btn.ZIndex = 5; btn.Parent = row

    btn.MouseButton1Click:Connect(function()
        val = not val
        Tw(track, { BackgroundColor3 = val and T.Accent or T.Muted }, 0.2)
        Tw(thumb, { Position = UDim2.new(0, val and 23 or 3, 0.5, -8) }, 0.2)
        onToggle(val)
    end)

    curY = curY + ROW_H + 6
    return val
end

local function makeSliderRow(label, min, max, default, suffix, onChanged)
    local ROW_H = 48

    local row = Instance.new("Frame")
    row.Size = UDim2.new(1,-PAD*2,0,ROW_H); row.Position = UDim2.new(0,PAD,0,curY)
    row.BackgroundColor3 = T.Card; row.BorderSizePixel = 0; row.ZIndex = 2; row.Parent = win
    Corner(row, 8); Stroke(row, T.Border)

    local nameLbl = Lbl({ Size=UDim2.new(0.6,0,0,18), Position=UDim2.new(0,12,0,6),
        Text=label, TextColor3=T.Text, Font=Enum.Font.GothamSemibold, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left, ZIndex=3 }, row)

    local valLbl = Lbl({ Size=UDim2.new(0.4,-12,0,18), Position=UDim2.new(0.6,0,0,6),
        Text=tostring(default)..suffix, TextColor3=T.Accent, Font=Enum.Font.GothamBold, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Right, ZIndex=3 }, row)

    local trackBg = Instance.new("Frame")
    trackBg.Size = UDim2.new(1,-24,0,6); trackBg.Position = UDim2.new(0,12,0,32)
    trackBg.BackgroundColor3 = T.Muted; trackBg.BorderSizePixel = 0; trackBg.ZIndex = 3; trackBg.Parent = row
    Corner(trackBg, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = T.Accent; fill.BorderSizePixel = 0; fill.ZIndex = 4; fill.Parent = trackBg
    Corner(fill, 3)
    local fillGrad = Instance.new("UIGradient")
    fillGrad.Color = ColorSequence.new(T.Accent, T.AccentD); fillGrad.Parent = fill

    local sThumb = Instance.new("Frame")
    sThumb.Size = UDim2.new(0,12,0,12); sThumb.AnchorPoint = Vector2.new(0.5,0.5)
    sThumb.Position = UDim2.new((default-min)/(max-min),0,0.5,0)
    sThumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
    sThumb.BorderSizePixel = 0; sThumb.ZIndex = 5; sThumb.Parent = trackBg; Corner(sThumb, 6)

    local dragging = false
    local curVal   = default

    local function updateSlider(pct)
        pct = math.clamp(pct, 0, 1)
        curVal = math.floor(min + (max-min) * pct)
        fill.Size     = UDim2.new(pct, 0, 1, 0)
        sThumb.Position = UDim2.new(pct, 0, 0.5, 0)
        valLbl.Text   = tostring(curVal) .. suffix
        onChanged(curVal)
    end

    trackBg.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            local pct = (i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
            updateSlider(pct)
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local pct = (i.Position.X - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X
            updateSlider(pct)
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    curY = curY + ROW_H + 6
end

