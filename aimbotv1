--[[
    TambayHub Combat Suite
    Aimbot + ESP + Hitbox Expander
    PC | Invisible FOV | Clean UI
]]

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local lp  = Players.LocalPlayer
local cam = workspace.CurrentCamera

-- ============================================================
-- SETTINGS
-- ============================================================

local CFG = {
    -- Aimbot
    AimbotOn       = false,
    TriggerKey     = Enum.UserInputType.MouseButton2,
    LockPart       = "Head",
    Sensitivity    = 0.18,  -- 0 = instant, higher = smoother
    FOVRadius      = 150,   -- screen pixels

    -- ESP
    ESPOn          = false,
    ESPBoxColor    = Color3.fromRGB(80, 130, 255),
    ESPNameColor   = Color3.fromRGB(220, 224, 242),
    ESPHealthColor = Color3.fromRGB(55, 215, 115),
    ESPTracerOn    = false,

    -- Hitbox
    HitboxOn       = false,
    HitboxSize     = Vector3.new(8, 8, 8),
}

-- ============================================================
-- STATE
-- ============================================================

local aimbotRunning = false
local aimbotConn    = nil
local espObjects    = {}   -- [player] = {box, name, health, tracer}
local hitboxObjects = {}   -- [player] = original sizes

-- ============================================================
-- HELPERS
-- ============================================================

local function getChar(p)  return p.Character end
local function getHRP(p)   local c = getChar(p); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum(p)   local c = getChar(p); return c and c:FindFirstChildOfClass("Humanoid") end
local function getHead(p)  local c = getChar(p); return c and c:FindFirstChild(CFG.LockPart) end

local function getCenter()
    return Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
end

local function isAlive(p)
    local h = getHum(p)
    return h and h.Health > 0
end

local function screenPos(pos)
    local v, onScreen = cam:WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), onScreen, v.Z
end

-- ============================================================
-- AIMBOT
-- ============================================================

local function getBestTarget()
    local best, bestDist = nil, CFG.FOVRadius
    local center = getCenter()

    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if not isAlive(p) then continue end
        local head = getHead(p)
        if not head then continue end
        local sp, onScreen = screenPos(head.Position)
        if not onScreen then continue end
        local dist = (center - sp).Magnitude
        if dist < bestDist then
            bestDist = dist
            best     = p
        end
    end
    return best
end

local function startAimbot()
    if aimbotConn then aimbotConn:Disconnect() end
    aimbotConn = RunService.RenderStepped:Connect(function()
        if not aimbotRunning then return end
        local target = getBestTarget()
        if not target then return end
        local head = getHead(target)
        if not head then return end

        local currentCF = cam.CFrame
        local goalCF    = CFrame.new(currentCF.Position, head.Position)
        cam.CFrame      = currentCF:Lerp(goalCF, CFG.Sensitivity)
    end)
end

local function stopAimbot()
    if aimbotConn then aimbotConn:Disconnect(); aimbotConn = nil end
    aimbotRunning = false
end

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == CFG.TriggerKey then
        aimbotRunning = true
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == CFG.TriggerKey then
        aimbotRunning = false
    end
end)

-- ============================================================
-- ESP
-- ============================================================

local function newDrawing(type, props)
    local d = Drawing.new(type)
    for k, v in pairs(props) do d[k] = v end
    return d
end

local function removeESP(p)
    if espObjects[p] then
        for _, d in pairs(espObjects[p]) do
            pcall(function() d:Remove() end)
        end
        espObjects[p] = nil
    end
end

local function createESP(p)
    removeESP(p)
    espObjects[p] = {
        box = newDrawing("Square", {
            Visible   = false,
            Color     = CFG.ESPBoxColor,
            Thickness = 1.5,
            Filled    = false,
            Transparency = 1,
        }),
        nameLabel = newDrawing("Text", {
            Visible  = false,
            Color    = CFG.ESPNameColor,
            Size     = 13,
            Font     = 2,
            Center   = true,
            Outline  = true,
            OutlineColor = Color3.fromRGB(0,0,0),
            Text     = p.Name,
        }),
        healthBar = newDrawing("Square", {
            Visible   = false,
            Color     = CFG.ESPHealthColor,
            Thickness = 1,
            Filled    = true,
            Transparency = 1,
        }),
        healthBg = newDrawing("Square", {
            Visible   = false,
            Color     = Color3.fromRGB(20,20,20),
            Thickness = 1,
            Filled    = true,
            Transparency = 1,
        }),
        tracer = newDrawing("Line", {
            Visible      = false,
            Color        = CFG.ESPBoxColor,
            Thickness    = 1,
            Transparency = 0.6,
        }),
    }
end

local function updateESP()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if not espObjects[p] then createESP(p) end

        local objs = espObjects[p]
        local char = getChar(p)
        local hrp  = char and getHRP(p)
        local hum  = char and getHum(p)

        if not CFG.ESPOn or not char or not hrp or not hum or hum.Health <= 0 then
            for _, d in pairs(objs) do d.Visible = false end
            continue
        end

        local rootPos = hrp.Position
        local topPos  = rootPos + Vector3.new(0, 3.2, 0)
        local botPos  = rootPos - Vector3.new(0, 2.8, 0)

        local topSP, onScreen = screenPos(topPos)
        local botSP           = screenPos(botPos)

        if not onScreen then
            for _, d in pairs(objs) do d.Visible = false end
            continue
        end

        local h    = math.abs(topSP.Y - botSP.Y)
        local w    = h * 0.55
        local x    = topSP.X - w / 2
        local y    = topSP.Y

        -- Box
        objs.box.Position  = Vector2.new(x, y)
        objs.box.Size      = Vector2.new(w, h)
        objs.box.Color     = CFG.ESPBoxColor
        objs.box.Visible   = true

        -- Name
        objs.nameLabel.Position = Vector2.new(topSP.X, y - 16)
        objs.nameLabel.Text     = p.Name
        objs.nameLabel.Visible  = true

        -- Health bar
        local hpPct   = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
        local barW    = 4
        local barX    = x - barW - 2
        local barH    = h
        local fillH   = barH * hpPct
        local hpColor = Color3.fromRGB(
            math.floor(255 * (1 - hpPct)),
            math.floor(255 * hpPct),
            60
        )
        objs.healthBg.Position = Vector2.new(barX, y)
        objs.healthBg.Size     = Vector2.new(barW, barH)
        objs.healthBg.Visible  = true

        objs.healthBar.Position = Vector2.new(barX, y + barH - fillH)
        objs.healthBar.Size     = Vector2.new(barW, fillH)
        objs.healthBar.Color    = hpColor
        objs.healthBar.Visible  = true

        -- Tracer
        if CFG.ESPTracerOn then
            local center = getCenter()
            objs.tracer.From    = Vector2.new(center.X, cam.ViewportSize.Y)
            objs.tracer.To      = botSP
            objs.tracer.Color   = CFG.ESPBoxColor
            objs.tracer.Visible = true
        else
            objs.tracer.Visible = false
        end
    end
end

Players.PlayerRemoving:Connect(function(p)
    removeESP(p)
end)

-- ============================================================
-- HITBOX EXPANDER
-- ============================================================

local function applyHitbox(p)
    if not CFG.HitboxOn then return end
    local char = getChar(p)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") then
            if not hitboxObjects[part] then
                hitboxObjects[part] = part.Size
            end
            part.Size = CFG.HitboxSize
        end
    end
end

local function restoreHitbox(p)
    local char = getChar(p)
    if not char then return end
    for _, part in ipairs(char:GetDescendants()) do
        if part:IsA("BasePart") and hitboxObjects[part] then
            part.Size       = hitboxObjects[part]
            hitboxObjects[part] = nil
        end
    end
end

local function refreshHitboxes()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if CFG.HitboxOn then
            applyHitbox(p)
        else
            restoreHitbox(p)
        end
    end
end

-- ============================================================
-- RENDER LOOP
-- ============================================================

RunService.RenderStepped:Connect(function()
    updateESP()
    if CFG.HitboxOn then refreshHitboxes() end
end)

